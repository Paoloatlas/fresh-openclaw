# OpenClaw Gateway
# Generate a token: openssl rand -hex 24
GATEWAY_TOKEN=replace-with-your-token

# Ports (these bind to 127.0.0.1 only — Caddy proxies inbound HTTPS)
GATEWAY_PORT=18789
BRIDGE_PORT=18790

# Image (pin a version in production, e.g. ghcr.io/openclaw/openclaw:2026.3.24)
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# QMD — hybrid memory search engine (vector + BM25).
# Must be installed on the host and compiled for the container's Node version.
# Install: docker run --rm -u root \
#   -v $HOME/.local/lib/qmd-node24:/opt/qmd \
#   ghcr.io/openclaw/openclaw:latest \
#   sh -c "cd /opt/qmd && npm init -y && npm install @tobilu/qmd"
QMD_PATH=/home/deploy/.local/lib/qmd-node24
